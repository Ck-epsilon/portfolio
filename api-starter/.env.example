# Environment Configuration
# Copy to .env:  cp .env.example .env
#
# For Docker Compose (PostgreSQL):
#   DATABASE_URL=postgresql+asyncpg://app:app_password@postgres:5432/app_db
#   SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_urlsafe(32))">

# Application
APP_NAME=API Starter
APP_VERSION=1.1.0
DEBUG=false

# Database — SQLite (zero-config dev) or PostgreSQL (production)
DATABASE_URL=sqlite+aiosqlite:///./api_starter.db

# JWT — GENERATE A REAL SECRET for production!
SECRET_KEY=dev-secret-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — restrict in production
# CORS_ORIGINS=["https://your-frontend.com"]

# Redis (optional, uncomment to enable)
# REDIS_URL=redis://localhost:6379/0
